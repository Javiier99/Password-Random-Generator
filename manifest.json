{
    "manifest_version": 3,
    "name": "Generador de contraseñas aleatorias",
    "version": "1.2",
    "description": "Una extensión GRATIS para crear contraseñas aleatorias, harto de extensiones de pago",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16" : "icons-16.png",
            "48" : "icons-48.png",
            "128" : "icons-128.png"
        }
    },
    "icons": {
        "16" : "icons-16.png",
        "48" : "icons-48.png",
        "128" : "icons-128.png"
    }
}